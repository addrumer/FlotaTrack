@page "/kierowcy"
@using Flota.Domain.Entities
@using Flota.Domain.Interfaces
@inject IKierowcaSerwis KierowcaSerwis
@inject IPrzydzialSerwis PrzydzialSerwis
@inject ITankowanieSerwis TankowanieSerwis
@inject IJSRuntime JS

@rendermode RenderMode.InteractiveServer

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold">Zespół Kierowców</h2>
            <p class="text-muted">Kartoteka pracowników i zarządzanie uprawnieniami.</p>
        </div>
        <div class="bg-light p-2 rounded border">
            <span class="fw-bold text-primary">@kierowcy.Count</span> pracowników
        </div>
    </div>

    <div class="card shadow-sm mb-5 border-0 bg-light">
        <div class="card-body">
            <h5 class="card-title text-primary mb-4">Zatrudnij nowego kierowcę</h5>

            <EditForm Model="@nowyKierowca" OnValidSubmit="DodajKierowce">
                <DataAnnotationsValidator />

                <div class="row g-3">
                    <div class="col-md-3">
                        <label class="form-label small text-muted">Imię</label>
                        <InputText class="form-control" placeholder="Jan" @bind-Value="nowyKierowca.Imie" />
                        <ValidationMessage For="@(() => nowyKierowca.Imie)" class="text-danger small" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small text-muted">Nazwisko</label>
                        <InputText class="form-control" placeholder="Kowalski" @bind-Value="nowyKierowca.Nazwisko" />
                        <ValidationMessage For="@(() => nowyKierowca.Nazwisko)" class="text-danger small" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small text-muted">PESEL (Opcjonalnie)</label>
                        <InputText class="form-control" placeholder="00000000000" @bind-Value="nowyKierowca.Pesel" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small text-muted">Nr Prawa Jazdy</label>
                        <InputText class="form-control text-uppercase" placeholder="ABC/12345" @bind-Value="nowyKierowca.NumerPrawaJazdy" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label small text-muted">E-mail</label>
                        <InputText class="form-control" placeholder="jan@firma.pl" @bind-Value="nowyKierowca.Email" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small text-muted">Telefon</label>
                        <InputText class="form-control" placeholder="+48..." @bind-Value="nowyKierowca.Telefon" />
                    </div>
                    <div class="col-md-5">
                        <label class="form-label small text-muted">Adres Zamieszkania</label>
                        <InputText class="form-control" placeholder="Ulica, Miasto" @bind-Value="nowyKierowca.Adres" />
                    </div>

                    <div class="col-md-2">
                        <label class="form-label small text-muted">Doświadczenie (lata)</label>
                        <InputNumber class="form-control" @bind-Value="nowyKierowca.LataDoswiadczenia" />
                    </div>
                    <div class="col-md-10 d-flex align-items-end justify-content-end">
                        <button class="btn btn-primary px-5 fw-bold shadow-sm" type="submit">
                            Zapisz w Bazie
                        </button>
                    </div>
                </div>
            </EditForm>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center flex-wrap gap-2">
            <h5 class="mb-0">Lista Pracowników</h5>
            <div style="width: 300px;">
                <input type="text" class="form-control form-control-sm" placeholder="Szukaj (imię, nazwisko, prawo jazdy, PESEL)..." @bind-value="filtrTekstowy" @bind-value:event="oninput" />
            </div>
        </div>
        <div class="card-body p-0">
            @if (kierowcy == null)
            {
            <div class="p-4 text-center">Ładowanie...</div>
            }
            else if (!kierowcy.Any())
            {
            <div class="p-5 text-center text-muted">
                <h4>Brak danych</h4>
                <p>Skorzystaj z formularza powyżej, aby dodać pierwszego pracownika.</p>
            </div>
            }
            else
            {
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light text-muted small text-uppercase">
                <tr>
                    <th class="ps-4">Kierowca</th>
                    <th>Kontakt</th>
                    <th>Uprawnienia / Staż</th>
                    <th>Status</th>
                    <th class="text-end pe-4">Akcje</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var k in kierowcyFiltrowani)
                {
                //Sprawdzamy, czy kierowca jest w trasie
                var czyWTrasie = zajeciKierowcyIds.Contains(k.Id);

                <tr>
                    <td class="ps-4">
                        <div class="d-flex align-items-center">
                            <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 40px; height: 40px;">
                                👤
                            </div>
                            <div>
                                <div class="fw-bold text-dark">@k.PelneImie</div>
                                <div class="small text-muted" style="font-size: 0.8rem;">
                                    @(string.IsNullOrEmpty(k.Pesel) ? "Brak PESEL" : k.Pesel)
                                </div>
                            </div>
                        </div>
                    </td>
                    <td>
                        <div class="small">
                            @if(!string.IsNullOrEmpty(k.Email))
                            {
                            <div class="mb-1 text-truncate" style="max-width: 150px;" title="@k.Email">@k.Email</div>
                            }
                            @if(!string.IsNullOrEmpty(k.Telefon))
                            {
                            <div class="text-muted">@k.Telefon</div>
                            }
                            else
                            {
                            <span class="text-muted">- brak kontaktu -</span>
                            }
                        </div>
                    </td>
                    <td>
                        <span class="badge bg-light text-dark border border-secondary-subtle">PJ: @k.NumerPrawaJazdy</span>
                        <div class="small text-muted mt-1">Staż: @k.LataDoswiadczenia lat</div>
                    </td>
                    <td>
                        @if (czyWTrasie)
                        {
                        <span class="badge bg-warning bg-opacity-10 text-warning px-3 py-2 rounded-pill border border-warning">
                                            W trasie
                                        </span>
                        }
                        else
                        {
                        <span class="badge bg-success bg-opacity-10 text-success px-3 py-2 rounded-pill border border-success">
                                            Dostępny
                                        </span>
                        }
                    </td>
                    <td class="text-end pe-4">
                        <button class="btn btn-sm btn-outline-primary me-2" @onclick="() => PokazSzczegoly(k)" title="Szczegóły">
                            Karta
                        </button>
                        <button class="btn btn-sm btn-outline-danger" @onclick="() => UsunKierowce(k.Id)" title="Usuń z bazy">
                            Usuń
                        </button>
                    </td>
                </tr>
                }
                </tbody>
            </table>
            }
        </div>
    </div>
</div>

@if (pokazModyfikatorSzczegoly && wybranyKierowca != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5); overflow-y: auto;">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content border-0 shadow">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title">Karta kierowcy: @wybranyKierowca.PelneImie</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="ZamknijSzczegoly"></button>
                </div>
                <div class="modal-body">
                    <div class="row mb-4">
                        <div class="col-md-6">
                            <h6>Dane osobowe i kontakt</h6>
                            <hr class="mt-1"/>
                            <table class="table table-sm table-borderless">
                                <tbody>
                                    <tr><td><strong>PESEL:</strong></td><td>@(string.IsNullOrEmpty(wybranyKierowca.Pesel) ? "Brak" : wybranyKierowca.Pesel)</td></tr>
                                    <tr><td><strong>Nr Prawa Jazdy:</strong></td><td><span class="badge bg-light text-dark border">@wybranyKierowca.NumerPrawaJazdy</span></td></tr>
                                    <tr><td><strong>E-mail:</strong></td><td>@(string.IsNullOrEmpty(wybranyKierowca.Email) ? "-" : wybranyKierowca.Email)</td></tr>
                                    <tr><td><strong>Telefon:</strong></td><td>@(string.IsNullOrEmpty(wybranyKierowca.Telefon) ? "-" : wybranyKierowca.Telefon)</td></tr>
                                    <tr><td><strong>Adres:</strong></td><td>@(string.IsNullOrEmpty(wybranyKierowca.Adres) ? "-" : wybranyKierowca.Adres)</td></tr>
                                    <tr><td><strong>Doświadczenie:</strong></td><td>@wybranyKierowca.LataDoswiadczenia lat</td></tr>
                                </tbody>
                            </table>
                        </div>
                        <div class="col-md-6 text-center d-flex flex-column justify-content-center align-items-center bg-light rounded p-3">
                            <small class="text-muted text-uppercase fw-bold">Wydatki na paliwo</small>
                            <h2 class="text-success fw-bold my-2">@sumaKosztowPaliwa.ToString("C")</h2>
                            <small class="text-muted">Liczba tankowań: @tankowaniaKierowcy.Count</small>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <h6 class="fw-bold">Historia Przydziałów</h6>
                            <hr class="mt-1"/>
                            <div style="max-height: 200px; overflow-y: auto;">
                                @if (przydzialyKierowcy.Any())
                                {
                                    <ul class="list-group list-group-flush small">
                                        @foreach (var p in przydzialyKierowcy)
                                        {
                                            <li class="list-group-item px-0 py-2">
                                                <strong>@p.Pojazd?.Marka @p.Pojazd?.Model</strong> (@p.Pojazd?.NumerRejestracyjny)<br/>
                                                <small class="text-muted">Od: @p.DataRozpoczecia.ToShortDateString() | Do: @(p.DataZakonczenia.HasValue ? p.DataZakonczenia.Value.ToShortDateString() : "W trasie")</small>
                                            </li>
                                        }
                                    </ul>
                                }
                                else
                                {
                                    <p class="text-muted small">Brak historii przydziałów.</p>
                                }
                            </div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <h6 class="fw-bold">Ostatnie Tankowania</h6>
                            <hr class="mt-1"/>
                            <div style="max-height: 200px; overflow-y: auto;">
                                @if (tankowaniaKierowcy.Any())
                                {
                                    <table class="table table-sm table-hover small">
                                        <thead>
                                            <tr>
                                                <th>Data</th>
                                                <th>Litry</th>
                                                <th>Koszt</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var t in tankowaniaKierowcy)
                                            {
                                                <tr>
                                                    <td>@t.Data.ToShortDateString()</td>
                                                    <td>@t.IloscLitrow.ToString("N1") L</td>
                                                    <td class="text-success fw-bold">@t.LacznyKoszt.ToString("C")</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                }
                                else
                                {
                                    <p class="text-muted small">Brak zarejestrowanych tankowań.</p>
                                }
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="ZamknijSzczegoly">Zamknij</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
private List<Kierowca> kierowcy = new();
private Kierowca nowyKierowca = new();
private string filtrTekstowy = "";

private IEnumerable<Kierowca> kierowcyFiltrowani =>
    string.IsNullOrWhiteSpace(filtrTekstowy)
        ? kierowcy
        : kierowcy.Where(k => k.Imie.Contains(filtrTekstowy, StringComparison.OrdinalIgnoreCase)
                             || k.Nazwisko.Contains(filtrTekstowy, StringComparison.OrdinalIgnoreCase)
                             || k.NumerPrawaJazdy.Contains(filtrTekstowy, StringComparison.OrdinalIgnoreCase)
                             || k.Pesel.Contains(filtrTekstowy, StringComparison.OrdinalIgnoreCase));

//Lista ID kierowców zajętych (mają auto)
private HashSet<int> zajeciKierowcyIds = new();

protected override async Task OnInitializedAsync()
{
await ZaladujDane();
}

private async Task ZaladujDane()
{
kierowcy = await KierowcaSerwis.PobierzWszystkichAsync();

//Logika Statusu:
var aktywne = await PrzydzialSerwis.PobierzAktywneAsync();
zajeciKierowcyIds = aktywne.Select(p => p.KierowcaId).ToHashSet();
}

private async Task DodajKierowce()
{
await KierowcaSerwis.DodajAsync(nowyKierowca);
nowyKierowca = new Kierowca(); // Reset formularza
await ZaladujDane();
}

private async Task UsunKierowce(int id)
{
//Blokada usuwania zajętego kierowcy
if (zajeciKierowcyIds.Contains(id))
{
await JS.InvokeVoidAsync("alert", "🛑 Nie można usunąć kierowcy, który jest aktualnie w trasie! Najpierw zakończ jego kurs.");
return;
}

bool potwierdzenie = await JS.InvokeAsync<bool>("confirm", "Czy na pewno chcesz usunąć tego pracownika?");
if (potwierdzenie)
{
    await KierowcaSerwis.UsunAsync(id);
    await ZaladujDane();
}
}

private Kierowca? wybranyKierowca;
private List<Przydzial> przydzialyKierowcy = new();
private List<Tankowanie> tankowaniaKierowcy = new();
private decimal sumaKosztowPaliwa = 0;
private bool pokazModyfikatorSzczegoly = false;

private async Task PokazSzczegoly(Kierowca k)
{
    wybranyKierowca = k;
    
    var wszystkiePrzydzialyAktywne = await PrzydzialSerwis.PobierzAktywneAsync();
    var wszystkiePrzydzialyHistoria = await PrzydzialSerwis.PobierzHistorieAsync();
    przydzialyKierowcy = wszystkiePrzydzialyAktywne.Concat(wszystkiePrzydzialyHistoria)
        .Where(p => p.KierowcaId == k.Id)
        .OrderByDescending(p => p.DataRozpoczecia)
        .ToList();
        
    var wszystkieTankowania = await TankowanieSerwis.PobierzWszystkieAsync();
    tankowaniaKierowcy = wszystkieTankowania
        .Where(t => t.KierowcaId == k.Id)
        .OrderByDescending(t => t.Data)
        .ToList();
        
    sumaKosztowPaliwa = tankowaniaKierowcy.Sum(t => t.LacznyKoszt);
    pokazModyfikatorSzczegoly = true;
}

private void ZamknijSzczegoly()
{
    pokazModyfikatorSzczegoly = false;
    wybranyKierowca = null;
}
}